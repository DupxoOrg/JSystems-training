pipeline{
    agent any
    stages{
        stage('Build'){
            steps{
                echo 'Build'
            }
        }
        stage('Test'){
            steps{
                echo 'Test'
            }
        }
    }
    post{
        always{
            echo 'I run always'
        }
        success{
            echo 'I run only if pipeline is successful'
        }
        failure{
            echo 'I run only if pipeline is failed'
        }
    }
}